PORT=8080
APP_BASE_URL=https://api.lifeatlas.cn
JWT_SECRET=replace-with-a-long-random-secret
DATA_FILE=./data/users.json
AUDIT_FILE=./data/audit.log

# Aliyun DirectMail SMTP. Replace these after opening Aliyun mail service.
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@mail.lifeatlas.cn
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="岁迹 <no-reply@mail.lifeatlas.cn>"

# Optional third-party login secrets. Keep these on the server only.
QQ_APP_ID=
QQ_APP_KEY=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
